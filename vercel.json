{
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://RAILWAY_URL/api/:path*" },
    { "source": "/thumbnails/:path*", "destination": "https://RAILWAY_URL/thumbnails/:path*" }
  ]
}
